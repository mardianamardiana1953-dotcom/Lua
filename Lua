-- [[ ALGORITMA 1: TARGETING ENGINE ]]
local function GetClosestTarget()
    local Target = nil
    local shortestDistance = math.huge
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild(AimbotSettings.TargetPart) then
            local pos, onScreen = Camera:WorldToViewportPoint(player.Character[AimbotSettings.TargetPart].Position)
            if onScreen then
                local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                if distance < shortestDistance then
                    Target = player
                    shortestDistance = distance
                end
            end
        end
    end
    return Target
end

-- [[ ALGORITMA 2: ADVANCED GOD MODE (NON-VISUAL) ]]
-- Teknik ini menghancurkan 'Neck' joint secara lokal agar server bingung dengan posisi hitbox kepala/badan
local function ToggleGodMode(state)
    local char = LocalPlayer.Character
    if state and char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            -- Bypass: Membuat tiruan humanoid agar server tidak men-kick karena 'No Humanoid'
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
            if char:FindFirstChild("Head") and char.Head:FindFirstChild("Neck") then
                char.Head.Neck:Destroy() -- Menghilangkan titik hit utama
            end
        end
    else
        -- Untuk mematikan God Mode, biasanya player harus Reset Character
        Rayfield:Notify({Title = "God Mode Info", Content = "Untuk menonaktifkan God Mode sepenuhnya, silakan Reset Character.", Duration = 5})
    end
end

-- [[ ALGORITMA 3: SECURITY & ANTICHEAT BYPASS ]]
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    -- Mencegah Kick & Deteksi Teleport
    if not checkcaller() and (method == "Kick" or method == "kick") then return nil end
    if method == "BreakJoints" then return nil end -- Melindungi dari penghancuran karakter sistem game
    return oldNamecall(self, unpack(args))
end)
setreadonly(mt, true)

