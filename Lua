-- Loop No Reload & Ammo Sync
task.spawn(function()
    while true do
        task.wait(0.5)
        if WeaponSettings.NoReload then
            pcall(function()
                if getgc then
                    for _, v in pairs(getgc(true)) do
                        if type(v) == "table" and rawget(v, "Ammo") then
                            rawset(v, "Ammo", 999)
                            rawset(v, "StoredAmmo", 999)
                        end
                    end
                end
            end)
        end
    end
end)

-- Loop Killer & Annihilation
task.spawn(function()
    while true do
        task.wait(KillerSettings.AttackSpeed)
        if KillerSettings.AutoKiller then
            pcall(function()
                local targetPlayer = Players:FindFirstChild(KillerSettings.TargetName)
                if targetPlayer and targetPlayer.Character and LocalPlayer.Character then
                    local myHRP = LocalPlayer.Character.HumanoidRootPart
                    local enemyHRP = targetPlayer.Character.HumanoidRootPart
                    local enemyHum = targetPlayer.Character.Humanoid
                    
                    if enemyHum.Health > 0 then
                        if enemyHum.Health <= 20 then
                            -- Cari hook terdekat
                            for _, obj in pairs(workspace:GetDescendants()) do
                                if obj.Name:lower():find("hook") and obj:IsA("BasePart") then
                                    myHRP.CFrame = obj.CFrame * CFrame.new(0, 5, 0)
                                    break
                                end
                            end
                        else
                            -- Nempel & Pukul
                            myHRP.CFrame = enemyHRP.CFrame * CFrame.new(0, 0, -2.5)
                            local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if tool then tool:Activate() end
                        end
                    end
                end
            end)
        end
    end
end)

-- Render Loop (Aimbot & ESP)
