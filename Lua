-- [[ SERVICES & VARIABLES ]]
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local Mouse = LocalPlayer:GetMouse()

-- State Management (Penyimpanan Status)
local AimbotSettings = { Enabled = false, Smoothing = 0.5, TargetPart = "HumanoidRootPart" }
local KillerSettings = { AutoKiller = false, AttackSpeed = 0.1, TargetName = "NamaPemainTarget" }
local RecoilSettings = { Enabled = false, Amount = 3, Speed = 0.05, Recovery = 2, RecovSpeed = 0.2 }

-- [[ ALGORITMA 1: TARGETING & UTILS ]]
local function GetClosestTarget()
    local Target = nil
    local shortestDistance = math.huge
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild(AimbotSettings.TargetPart) then
            local pos, onScreen = Camera:WorldToViewportPoint(player.Character[AimbotSettings.TargetPart].Position)
            if onScreen then
                local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                if distance < shortestDistance then
                    Target = player
                    shortestDistance = distance
                end
            end
        end
    end
    return Target
end

local function GetClosestHook()
    local closestHook = nil
    local dist = math.huge
    for _, v in pairs(workspace:GetDescendants()) do
        if (v.Name:lower():find("hook") or v.Name:lower():find("sacrifice")) and (v:IsA("BasePart") or v:IsA("Model")) then
            local pos = v:IsA("Model") and v.PrimaryPart and v.PrimaryPart.Position or v.Position
            if pos then
                local d = (LocalPlayer.Character.HumanoidRootPart.Position - pos).Magnitude
                if d < dist then
                    dist = d
                    closestHook = v
                end
            end
        end
    end
    return closestHook
end

-- [[ ALGORITMA 2: REALISTIC RECOIL SYSTEM ]]
local function applyRecoil()
    if not RecoilSettings.Enabled then return end
    
    local recoilGoal = {
        CFrame = Camera.CFrame * CFrame.Angles(math.rad(RecoilSettings.Amount), math.rad(math.random(-1,1)), 0)
    }
    local tweenInfo = TweenInfo.new(RecoilSettings.Speed, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    local tween = TweenService:Create(Camera, tweenInfo, recoilGoal)
    tween:Play()

    task.wait(RecoilSettings.Speed)
    
    local recoveryGoal = {
        CFrame = Camera.CFrame * CFrame.Angles(math.rad(-RecoilSettings.Recovery), 0, 0)
    }
    local recoveryTweenInfo = TweenInfo.new(RecoilSettings.RecovSpeed, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
    TweenService:Create(Camera, recoveryTweenInfo, recoveryGoal):Play()
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        applyRecoil()
    end
end)

-- [[ ALGORITMA 3: SECURITY BYPASS ]]
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if not checkcaller() and (method == "Kick" or method == "kick") then return nil end
    return oldNamecall(self, ...)
end)
setreadonly(mt, true)

