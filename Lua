})

MainTab:CreateToggle({
   Name = "Non-Visual God Mode",
   CurrentValue = false,
   Callback = function(Value) ToggleGodMode(Value) end,
})

MainTab:CreateToggle({
   Name = "No Reload (Safe Mode)",
   CurrentValue = false,
   Callback = function(Value) Settings.NoReload = Value end,
})

--- LOOPS (OPTIMIZED WITH TASK.WAIT) ---

-- Loop No Reload (Diperambat ke 1 detik agar Xeno Legacy tidak overheat)
task.spawn(function()
    while true do
        task.wait(1)
        if Settings.NoReload and getgc then
            pcall(function()
                for _, v in pairs(getgc(true)) do
                    if type(v) == "table" and rawget(v, "Ammo") then
                        rawset(v, "Ammo", 999)
                    end
                end
            end)
        end
    end
end)

-- Loop Killer (Focus pada efisiensi)
task.spawn(function()
    while true do
        task.wait(0.1) -- Sedikit delay agar tidak dianggap spam oleh server
        if Settings.Killer then
            pcall(function()
                local target = Players:FindFirstChild(Settings.TargetName)
                if target and target.Character and LocalPlayer.Character then
                    local myHRP = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    local enHRP = target.Character:FindFirstChild("HumanoidRootPart")
                    
                    if myHRP and enHRP and target.Character.Humanoid.Health > 0 then
                        myHRP.CFrame = enHRP.CFrame * CFrame.new(0, 0, -3)
                        local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                        if tool then tool:Activate() end
                    end
                end
            end)
        end
    end
end)

-- Loop God Mode Protection (Mencegah kematian mendadak)
RunService.Heartbeat:Connect(function()
    if Settings.GodMode then
        pcall(function()
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 and hum.Health < 20 then
                -- Menjaga HP tidak menyentuh angka 0 secara lokal
                hum.Health = 100 
            end
        end)
    end
end)

Rayfield:Notify({Title = "Ready", Content = "Timi Hub V12 Lite Loaded!", Duration = 3})
