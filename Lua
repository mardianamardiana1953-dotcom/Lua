--- LOOPS ---
-- Loop Aimbot
RunService.RenderStepped:Connect(function()
    if AimbotSettings.Enabled then
        local Target = GetClosestTarget()
        if Target and Target.Character then
            local targetPos = Target.Character[AimbotSettings.TargetPart].Position
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, targetPos), AimbotSettings.Smoothing)
        end
    end
end)

-- Loop Killer
task.spawn(function()
    while true do
        task.wait(KillerSettings.AttackSpeed)
        if KillerSettings.AutoKiller then
            pcall(function()
                local targetPlayer = Players:FindFirstChild(KillerSettings.TargetName)
                if targetPlayer and targetPlayer.Character and LocalPlayer.Character then
                    local myHRP = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    local targetHRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                    local targetHum = targetPlayer.Character:FindFirstChild("Humanoid")

                    if myHRP and targetHRP then
                        if targetHum and targetHum.Health <= 15 then
                            local hook = GetClosestHook()
                            if hook then
                                local hookPos = hook:IsA("Model") and hook:GetModelCFrame() or hook.CFrame
                                myHRP.CFrame = hookPos * CFrame.new(0, 5, 0)
                            end
                        else
                            myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, -2.5)
                            local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if tool then tool:Activate() end
                            local remote = game:GetService("ReplicatedStorage"):FindFirstChild("Attack") or game:GetService("ReplicatedStorage"):FindFirstChild("Hit")
                            if remote then remote:FireServer(targetPlayer.Character) end
                        end
                    end
                end
            end)
        end
    end
end)

