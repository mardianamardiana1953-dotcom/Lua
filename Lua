-- [[ TIMI'S HUB V12 - XENO ULTRA LIGHT & FIXED GOD ]]

-- Optimasi Xeno: Mematikan render yang tidak perlu saat execute
if not game:IsLoaded() then game.Loaded:Wait() end

-- [[ CORE INITIALIZATION ]]
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- [[ SERVICES ]]
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- State Management (Dibuat sesedikit mungkin agar hemat RAM)
local Settings = {
    Aimbot = false,
    Killer = false,
    NoReload = false,
    GodMode = false,
    TargetName = ""
}

-- [[ FIX GOD MODE: DESYNC METHOD ]]
-- Lebih stabil dari destroy neck, tidak bikin karakter nyangkut
local function ToggleGodMode(state)
    Settings.GodMode = state
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    if hum then
        if state then
            -- Mematikan state yang meregistrasi damage/kematian
            hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        else
            hum:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
            Rayfield:Notify({Title = "Status", Content = "Reset karakter untuk menormalkan Hitbox.", Duration = 3})
        end
    end
end

-- [[ SECURITY: LIGHTWEIGHT BYPASS ]]
local success, err = pcall(function()
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    local old = mt.__namecall
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if not checkcaller() and (method == "Kick" or method == "kick") then 
            return nil 
        end
        return old(self, ...)
    end)
    setreadonly(mt, true)
end)

-- [[ WINDOW ]]
local Window = Rayfield:CreateWindow({
   Name = "Timi Hub V12 | Xeno Lite",
   LoadingTitle = "Xeno Legacy Optimized",
   ConfigurationSaving = { Enabled = false }, -- Dimatikan agar lebih ringan
   Theme = "Darkblue",
   KeySystem = false 
})

local MainTab = Window:CreateTab("Main", 4483362458)

MainTab:CreateInput({
   Name = "Target Name",
