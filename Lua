-- [[ ALGORITMA 1: TARGETING ENGINE (XENO OPTIMIZED) ]]
local function GetClosestTarget()
    local Target = nil
    local shortestDistance = math.huge
    
    -- Menggunakan pcall agar tidak crash jika player left tiba-tiba
    pcall(function()
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild(AimbotSettings.TargetPart) then
                local pos, onScreen = Camera:WorldToViewportPoint(player.Character[AimbotSettings.TargetPart].Position)
                if onScreen then
                    local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                    if distance < shortestDistance then
                        Target = player
                        shortestDistance = distance
                    end
                end
            end
        end
    end)
    return Target
end

-- [[ ALGORITMA 2: ADVANCED GOD MODE ]]
local function ToggleGodMode(state)
    local char = LocalPlayer.Character
    if state and char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            -- Mencegah kematian saat neck dihancurkan
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
            task.defer(function() -- Menggunakan defer agar Xeno tidak lag saat penghancuran part
                if char:FindFirstChild("Head") and char.Head:FindFirstChild("Neck") then
                    char.Head.Neck:Destroy()
                end
            end)
        end
    else
        Rayfield:Notify({Title = "God Mode Info", Content = "Silakan Reset Character untuk kembali normal.", Duration = 5})
    end
end

